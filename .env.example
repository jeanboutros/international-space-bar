# Project environment — determines which config.<env>.yaml is loaded
# Valid values: dev, test, prod
ISB_PROJECT_ENVIRONMENT=dev

# Config file path override (optional)
# Precedence: --config CLI arg > ISB_CONFIG_PATH > default (<cwd>/config.<env>.yaml)
# ISB_CONFIG_PATH=./config.dev.yaml

# API key for local development — used by the bearer-token guard
ISB_OPENRESPONSES_API_KEY=local-dev-key

# Server port (default: 3000)
# PORT=3000
