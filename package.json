{
	"type": "module",
	"author": {
		"name": "Jean Boutros",
		"url": "https://github.com/jeanboutros"
	},
	"name": "international-space-bar",
	"version": "0.1.0",
	"scripts": {
		"dev": "pnpm dev:server",
		"dev:server": "NODE_OPTIONS='--stack-trace-limit=50' && tsx --env-file=.env src/international-space-bar-server/main.ts --environment dev",
		"build": "pnpm build:server",
		"build:server": "tsx watch src/international-space-bar-server/main.ts --format esm --outDir dist",
		"start": "pnpm start:server",
		"start:server": "node --env-file=.env dist/international-space-bar-server/main.js",
		"test": "node --import tsx --test 'src/**/*.test.ts'",
		"lint": "biome lint src/ && eslint",
		"lint:fix": "biome lint --write src/ && eslint --fix",
		"format": "biome format --write src/",
		"check": "biome check --write src/ && eslint --fix",
		"generate:types": "openapi-typescript docs/openapi/openresponses.json -o src/international-space-bar-server/openresponses/openresponses.generated.d.ts && node scripts/fix-openapi-discriminators.mjs src/international-space-bar-server/openresponses/openresponses.generated.d.ts",
		"generate:schemas": "kubb generate",
		"test:compliance": "node scripts/compliance-test.mjs"
	},
	"dependencies": {
		"@langchain/anthropic": "^1.3.27",
		"@langchain/core": "^1.1.41",
		"@langchain/langgraph": "^1.2.9",
		"@langchain/tavily": "^1.2.0",
		"@nestjs/common": "^11.1.19",
		"@nestjs/core": "^11.1.19",
		"@nestjs/platform-express": "^11.1.19",
		"@nestjs/platform-ws": "^11.1.19",
		"@nestjs/websockets": "^11.1.19",
		"deepagents": "^1.9.0",
		"langchain": "^1.3.4",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"ws": "^8.18.0",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@eslint/js": "^10.0.1",
		"@kubb/cli": "^4.37.4",
		"@kubb/core": "^4.37.4",
		"@kubb/plugin-oas": "^4.37.4",
		"@kubb/plugin-ts": "^4.37.4",
		"@kubb/plugin-zod": "^4.37.4",
		"@langchain/ollama": "^1.2.6",
		"@nestjs/testing": "^11.1.19",
		"@types/express": "^5.0.6",
		"@types/node": "^22",
		"@types/supertest": "^7.2.0",
		"@types/ws": "^8.18.1",
		"eslint": "^10.2.1",
		"openapi-typescript": "^7.13.0",
		"supertest": "^7.2.2",
		"tsup": "^8.5.1",
		"tsx": "^4",
		"typescript": "^5",
		"typescript-eslint": "^8.59.0"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
